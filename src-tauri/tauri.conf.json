{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillManager",
  "version": "0.1.0",
  "identifier": "com.l3e.skillmanager",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "title": "Skill Inventory Matrix",
        "width": 1480,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
